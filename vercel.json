{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/clubedascolecionadoras/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/frames/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/covers/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/verso-card.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/_serverFn/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/_serverFn/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/assets/:path*"
    },
    {
      "source": "/avatar/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/avatar/:path*"
    },
    {
      "source": "/autographs/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/autographs/:path*"
    },
    {
      "source": "/covers/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/covers/:path*"
    },
    {
      "source": "/card story/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/card%20story/:path*"
    },
    {
      "source": "/banner/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/banner/:path*"
    },
    {
      "source": "/frames/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/frames/:path*"
    },
    {
      "source": "/icons/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/icons/:path*"
    },
    {
      "source": "/logo-ls.png",
      "destination": "https://clube-das-colecionadoras2.vercel.app/logo-ls.png"
    },
    {
      "source": "/logo_text.png",
      "destination": "https://clube-das-colecionadoras2.vercel.app/logo_text.png"
    },
    {
      "source": "/verso-card.png",
      "destination": "https://clube-das-colecionadoras2.vercel.app/verso-card.png"
    },
    {
      "source": "/verso-card.webp",
      "destination": "https://clube-das-colecionadoras2.vercel.app/verso-card.webp"
    },
    {
      "source": "/card_pink.png",
      "destination": "https://clube-das-colecionadoras2.vercel.app/card_pink.png"
    },
    {
      "source": "/card_wine.png",
      "destination": "https://clube-das-colecionadoras2.vercel.app/card_wine.png"
    },
    {
      "source": "/clubedascolecionadoras/assets/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/assets/:path*"
    },
    {
      "source": "/clubedascolecionadoras",
      "destination": "https://clube-das-colecionadoras2.vercel.app/clubedascolecionadoras"
    },
    {
      "source": "/clubedascolecionadoras/:path*",
      "destination": "https://clube-das-colecionadoras2.vercel.app/clubedascolecionadoras/:path*"
    },
    {
      "source": "/lista120livrossaficos",
      "destination": "https://lista-120-livros-saficos.vercel.app/"
    },
    {
      "source": "/lista120livrossaficos/:path*",
      "destination": "https://lista-120-livros-saficos.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
